{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./shared/*"],
      "@modules/*": ["./modules/*"],
      "~/*": ["./app/*"],
      "@/*": ["./app/*"]
    }
  },
  "include": ["app/**/*.ts", "app/**/*.vue", "server/**/*.ts", "shared/**/*.ts", "modules/**/*.ts", "nuxt.config.ts"],
  "exclude": ["node_modules", ".nuxt", "dist"]
}
