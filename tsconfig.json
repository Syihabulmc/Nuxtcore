{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./shared/*"],
      "@modules/*": ["./modules/*"],
      "~/*": ["./app/*"],
      "@/*": ["./app/*"]
    }
  },
  "include": [".nuxt/nuxt.d.ts", ".nuxt/**/*.d.ts", "app/**/*.ts", "app/**/*.vue", "server/**/*.ts", "shared/**/*.ts", "modules/**/*.ts", "nuxt.config.ts"],
  "exclude": ["node_modules", "dist"]
}
